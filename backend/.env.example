# Slack credentials — copy this file to .env and fill in real values
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# AI/ML keys — required by synapse_ai.config.Settings
OPENAI_API_KEY=sk-your-openai-key-here
BRAVE_API_KEY=your-brave-api-key-here

# Decision Cards channel
SLACK_DECISIONS_CHANNEL_ID=C0123ABC456
GITHUB_TOKEN=github_pat_placeholder

# Logging
LOG_LEVEL=INFO
